# Altair Curriculum — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.
#
# To obtain these values:
#   1. Go to https://supabase.com and create a project.
#   2. In your project, go to Settings > API.
#   3. Copy the Project URL and the anon/public key.
#
# Never use the service_role key in frontend code.
# The anon key is safe to expose in browser JavaScript
# because Row Level Security controls what it can access.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# GitHub Actions: add these as repository secrets at
# Settings > Secrets and variables > Actions, then
# reference them in deploy.yml as ${{ secrets.SUPABASE_URL }}

